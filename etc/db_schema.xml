<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="bydn_warm_item">
        <column xsi:type="bigint" name="entity_id" nullable="false" identity="true" padding="10" unsigned="true" comment="Id"/>
        <column xsi:type="varchar" name="type" nullable="false" length="32" comment="Page type"/>
        <column xsi:type="text" name="info" nullable="false" comment="Warm extra info"/>
        <column xsi:type="int" name="store_id" nullable="false" unsigned="true" comment="Store ID"/>
        <column xsi:type="int" name="priority" nullable="false" unsigned="true" comment="Warm priority"/>
        <column xsi:type="int" name="status" nullable="false" unsigned="true" comment="Warm status"/>
        <column xsi:type="text" name="url" nullable="true" comment="Generated URL"/>
        <column xsi:type="decimal" name="time" scale="4" precision="12" nullable="true" comment="Curl execution time"/>
        <column xsi:type="smallint" name="result_code" nullable="true" comment="HTTP result code"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Creation date"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Update date"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
    </table>
    <table name="bydn_warm_stats">
        <column xsi:type="bigint" name="id" nullable="false" identity="true" padding="10" unsigned="true" comment="Id"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Creation date"/>
        <column xsi:type="int" name="pending_items" nullable="false" unsigned="true" comment="Pending items"/>
        <column xsi:type="int" name="done_items" nullable="false" unsigned="true" comment="Done items"/>
        <column xsi:type="int" name="error_items" nullable="false" unsigned="true" comment="Error items"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>
    </table>
</schema>
